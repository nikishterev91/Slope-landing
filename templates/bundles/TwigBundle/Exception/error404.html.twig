{% extends 'base.html.twig' %}

{% block title %}{{ 'meta.title' | trans({}, 'messages') }}{% endblock %}

{#{% set locale = {{ app.request.locale }} %}#}

{% block body %}
    <main class="error-page">
        <div class="error-page__media"></div>
        <div class="error-page__overlay"></div>

        <div class="error-page__container">
            <div class="error-page__card glass-panel crosshair-container">
                <header class="error-page__head">
                    <span class="eyebrow">{{ 'error_page.error_404' | trans({}, 'messages') }}</span>
                    <h1 class="error-page__title">
                        {{ 'error_page.space' | trans({}, 'messages') }} <br />
                        <span>{{ 'error_page.undefined' | trans({}, 'messages') }}</span>
                    </h1>
                </header>

                <div class="error-page__body">
                    <p class="error-page__desc">
                        {{ 'error_page.coordinates' | trans({}, 'messages') }}
                    </p>

                    <div class="error-page__actions">
                        <a href="{{ path('homepage') }}" class="btn btn--gold">
                            {{ 'error_page.return_to_project' | trans({}, 'messages') }}
                        </a>
                        <a href="{{ path('homepage') }}#contact" class="btn btn--ghost">
                            {{ 'error_page.report_issue' | trans({}, 'messages') }}
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <style>
        /* ============================================================
           SLOPE — 404 Error Component Context Override Styles
           ============================================================ */
        .error-page {
            position: relative;
            min-height: 100vh;
            width: 100vw;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1.5rem;
            overflow: hidden;
            background: var(--bg-dark);
        }

        /* Cinematic background image wrapper matches hero logic */
        .error-page__media {
            position: absolute;
            inset: 0;
            background: url("https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?auto=format&fit=crop&w=2000&q=80") center / cover no-repeat;
            z-index: 1;
            transform: scale(1.05);
            animation: slowZoom 25s ease-out forwards;
            filter: grayscale(20%) brightness(90%);
        }

        .light-mode .error-page__media {
            filter: sepia(10%) brightness(95%);
        }

        /* Custom vignette overlay framework */
        .error-page__overlay {
            position: absolute;
            inset: 0;
            z-index: 2;
            background: radial-gradient(
                circle at center,
                rgba(10, 9, 7, 0.45) 0%,
                var(--bg-dark) 90%
            );
            transition: background 0.4s var(--ease);
        }

        /* Content framing system */
        .error-page__container {
            position: relative;
            z-index: 10;
            width: 100%;
            max-width: 580px;
        }

        /* Custom glass block alignment overrides */
        .error-page__card {
            padding: 4rem 3.5rem;
            text-align: left;
        }

        .error-page__title {
            font-family: var(--outfit);
            font-weight: 500;
            font-size: clamp(2.5rem, 6vw, 4rem);
            line-height: 1.05;
            letter-spacing: -0.03em;
            margin-bottom: 1.5rem;
            color: var(--text-light);
        }

        .error-page__title span {
            font-family: var(--serif);
            font-style: italic;
            font-weight: 300;
            color: var(--text-dim);
        }

        .error-page__desc {
            font-size: 0.95rem;
            line-height: 1.6;
            color: var(--text-dim);
            max-width: 42ch;
            margin-bottom: 3rem;
        }

        /* Utility UI alignment spacing */
        .error-page__actions {
            display: flex;
            flex-wrap: wrap;
            gap: 1.25rem;
            align-items: center;
        }

        .error-page__actions .btn {
            padding: 1rem 2rem;
            font-size: 0.75rem;
        }

        /* ============================================================
           Responsive Grid Adjustments
           ============================================================ */
        @media (max-width: 577px){
            .error-page__actions {
                flex-direction: column;
                align-items: stretch;
            }
        }

        @media (max-width: 480px) {
            .error-page__card {
                padding: 3rem 1.75rem;
            }
        }

        .error-page__actions .btn {
            @media (max-width: 577px){
                justify-content: center;
            }

            @media (max-width: 330px) {
                font-size: 0.7rem
            }

            @media (max-width: 318px) {
                font-size: 0.6rem
            }
        }

    </style>
{% endblock %}
