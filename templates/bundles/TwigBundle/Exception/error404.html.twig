{% extends 'base.html.twig' %}

{% block title %}{{ 'meta.title' | trans({}, 'messages') }}{% endblock %}

{% block body %}
    <main class="error-page">
        <div class="error-page__media"></div>
        <div class="error-page__overlay"></div>

        <div class="error-page__container">
            <div class="error-page__card glass-panel crosshair-container">
                <header class="error-page__head">
                    <span class="eyebrow">{{ 'error_page.error_404' | trans({}, 'messages') }}</span>
                    <h1 class="error-page__title">
                        {{ 'error_page.space' | trans({}, 'messages') }} <br />
                        <span>{{ 'error_page.undefined' | trans({}, 'messages') }}</span>
                    </h1>
                </header>

                <div class="error-page__body">
                    <p class="error-page__desc">
                        {{ 'error_page.coordinates' | trans({}, 'messages') }}
                    </p>

                    <div class="error-page__actions">
                        <a href="{{ path('homepage') }}" class="btn btn--gold">
                            {{ 'error_page.return_to_project' | trans({}, 'messages') }}
                        </a>
                        <a href="{{ path('homepage') }}#contact" class="btn btn--ghost">
                            {{ 'error_page.report_issue' | trans({}, 'messages') }}
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </main>
{% endblock %}
