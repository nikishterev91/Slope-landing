<header class="nav" id="nav">
    <div class="nav__inner w-100">
        <a href="#hero" class="nav__logo" aria-label="Slope home">
            <svg class="nav__logo-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="12" x2="12" y2="3" />
                <line x1="12" y1="12" x2="4" y2="20" />
                <line x1="12" y1="12" x2="20" y2="20" />
            </svg>
            <span>Slope</span>
        </a>

        <nav class="nav__links" aria-label="Primary">
            <a href="#properties">{{ 'navigation.residences' | trans({}, 'messages') }}</a>
            <a href="#showcase">{{ 'navigation.tour_3d' | trans({}, 'messages') }}</a>
            <a href="#contact">{{ 'navigation.contact' | trans({}, 'messages') }}</a>
        </nav>

        <div class="nav__utils">
            <div class="nav__lang" aria-label="Language selector">
                <a href="{{ path('homepage', {'_locale': 'en'}) }}" class="nav__lang-link {% if app.request.locale == 'en' %}is-active{% endif %}">EN</a>
                <span class="nav__lang-separator">|</span>
                <a href="{{ path('homepage', {'_locale': 'bg'}) }}" class="nav__lang-link {% if app.request.locale == 'bg' %}is-active{% endif %}">BG</a>
            </div>

            <button id="themeToggle" class="btn--icon nav__theme-toggle" aria-label="{{ 'navigation.toggle_theme' | trans({}, 'messages') }}">
                <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="5"></circle>
                    <line x1="12" y1="1" x2="12" y2="3"></line>
                    <line x1="12" y1="21" x2="12" y2="23"></line>
                    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
                    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
                    <line x1="1" y1="12" x2="3" y2="12"></line>
                    <line x1="21" y1="12" x2="23" y2="12"></line>
                    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
                    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
                </svg>
                <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
                </svg>
            </button>

            <a href="#contact" class="btn btn--gold nav__cta">{{ 'navigation.inquire_now' | trans({}, 'messages') }}</a>
        </div>

        <button class="nav__toggle" id="navToggle" aria-label="{{ 'navigation.toggle_menu' | trans({}, 'messages') }}" aria-expanded="false">
            <span></span><span></span>
        </button>
    </div>
</header>
