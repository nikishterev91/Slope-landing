<section class="showcase section" id="showcase">
    <div class="section__head reveal">
        <p class="eyebrow">{{ 'showcase.eyebrow' | trans({}, 'messages') }}</p>
        <h2 class="section__title">{{ 'showcase.title' | trans({}, 'messages') }}</h2>
    </div>

    <div class="showcase__stage reveal" id="showcaseStage">
        <img
            class="showcase__bg"
            src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?auto=format&fit=crop&w=1600&q=80"
            alt="Interior render of the residence"
            loading="lazy"
        />
        <div class="showcase__ui">
            <div class="showcase__badge">{{ 'showcase.title' | trans({}, 'messages') }}</div>
            <h3 class="showcase__heading">{{ 'showcase.heading' | trans({}, 'messages') }}</h3>
            <p class="showcase__text">
                {{ 'showcase.description' | trans({}, 'messages') }}            </p>
            <button class="btn btn--gold showcase__btn" id="launch3d" type="button">
                <span class="showcase__btn-dot"></span> {{ 'showcase.launch' | trans({}, 'messages') }}
            </button>
        </div>
        <div class="showcase__hint">{{ 'showcase.hint' | trans({}, 'messages') }}</div>
    </div>
</section>
