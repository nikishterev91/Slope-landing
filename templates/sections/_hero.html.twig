<section class="hero" id="hero">
    <div class="hero__media" role="img" aria-label="Modern architectural residence at dusk"></div>
    <div class="hero__overlay"></div>

    <div class="hero__grid">
        <div class="hero__left">
            <p class="eyebrow reveal">{{ 'hero.eyebrow' | trans({}, 'messages')  }}</p>
            <h1 class="hero__title reveal">
                {{ 'hero.title.high_end' | trans({}, 'messages')  }}<br />
                {{ 'hero.title.residential_design' | trans({}, 'messages')  }}<br />
                {{ 'hero.title.and_build' | trans({}, 'messages')  }}
            </h1>
            <div class="hero__bottom-row reveal">
                <a href="#contact" class="btn btn--white">{{ 'hero.cta' | trans({}, 'messages')  }}</a>
                <p class="hero__lede-dark">
                    {{ 'hero.description' | trans({}, 'messages')  }}
                </p>
            </div>
        </div>

        <div class="hero__right">
            <div class="hero__stats-row">
                <div class="stat-card glass-panel crosshair-container reveal">
                    <div class="stat-card__number">10+</div>
                    <div class="stat-card__label">{{ 'stats.years_experience' | trans({}, 'messages')  }}</div>
                </div>
                <div class="stat-card glass-panel crosshair-container reveal">
                    <div class="stat-card__number">75+</div>
                    <div class="stat-card__label">{{ 'stats.completed_projects' | trans({}, 'messages')  }}</div>
                </div>
            </div>

            <div class="preview-card glass-panel reveal">
                <div class="preview-card__media">
                    <img
                        class="preview-card__img active"
                        src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&w=600&q=80"
                        alt="The North House — Residence 01"
                    />
                    <img
                        class="preview-card__img"
                        src="https://images.unsplash.com/photo-1512917774080-9991f1c4c750?auto=format&fit=crop&w=600&q=80"
                        alt="The South House — Residence 02"
                    />
                    <span class="preview-card__badge">{{ 'preview.featured_properties' | trans({}, 'messages')  }}</span>
                </div>

                <div class="preview-card__content">
                    <div class="preview-card__icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="12" y1="12" x2="12" y2="3" />
                            <line x1="12" y1="12" x2="4" y2="20" />
                            <line x1="12" y1="12" x2="20" y2="20" />
                        </svg>
                    </div>

                    <div class="preview-card__slides">
                        <div class="preview-card__slide active">
                            <h3 class="preview-card__title">The North House</h3>
                            <p class="preview-card__desc">
                                {{ 'properties.residence_01.description' | trans({}, 'messages')  }}
                            </p>
                        </div>
                        <div class="preview-card__slide">
                            <h3 class="preview-card__title">The South House</h3>
                            <p class="preview-card__desc">
                                {{ 'properties.residence_02.description' | trans({}, 'messages')  }}
                            </p>
                        </div>
                    </div>

                    <div class="preview-card__footer">
                        <div class="preview-card__dots">
                            <span class="preview-card__dot active"></span>
                            <span class="preview-card__dot"></span>
                        </div>
                        <div class="preview-card__nav">
                            <button class="preview-card__arrow" id="prevSlide" aria-label="Previous property">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="19" y1="12" x2="5" y2="12" />
                                    <polyline points="12 19 5 12 12 5" />
                                </svg>
                            </button>
                            <button class="preview-card__arrow" id="nextSlide" aria-label="Next property">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="5" y1="12" x2="19" y2="12" />
                                    <polyline points="12 5 19 12 12 19" />
                                </svg>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <a href="#properties" class="hero__scroll" aria-label="Scroll to residences">
        <span>{{ 'hero.scroll' | trans({}, 'messages')  }}</span>
        <span class="hero__scroll-line"></span>
    </a>
</section>
